//ez egy hash-map szerűség, ide lehet bármit tenni és az adott generátor fel tudja használni
config {
    baseNamespace: "ExampleAPI" 
    prefix: "/api/v1"
}

@route(users)
entity User {
    @unique
    username : string
    posts : List<Post>
}

@route(posts)
entity Post {
    title : string
    content : string
    author : User
}
