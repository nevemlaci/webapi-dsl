//ez egy hash-map szerűség, ide lehet bármit tenni és az adott generátor fel tudja használni
config {
    baseNamespace: "ExampleAPI" 
    prefix: "/api/v1"
}

@Route("users")
entity User {
    @Unique
    @Required
    @Filter(FilterType::Search)
    username : string
    @Filter(FilterType::Range)
    accountAge : int
    posts : List<Post>
}

@Route("posts")
entity Post {
    @Required
    title : string
    @Required
    content : string
    author : User
}
